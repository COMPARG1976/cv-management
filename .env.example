# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_DB=cv_management
POSTGRES_USER=cv_user
POSTGRES_PASSWORD=cv_password_change_me

# ── Backend Security ──────────────────────────────────────────────────────────
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=720

# ── Auth Provider ─────────────────────────────────────────────────────────────
# "fake" per sviluppo locale, "entra" per Microsoft Azure AD
AUTH_PROVIDER=fake

# Password di default per utenti creati in modalità fake
DEFAULT_USER_PASSWORD=Demo123!
ADMIN_USER_PASSWORD=Admin123!

# ── Microsoft Entra ID (Azure AD) ────────────────────────────────────────────
# Se configurati, il bottone "Entra con Autenticazione Aziendale" appare in login.
# Un utente Entra non presente nel DB viene creato automaticamente (ruolo USER).
# ENTRA_TENANT_ID=your-tenant-id
# ENTRA_CLIENT_ID=your-client-id
# ENTRA_CLIENT_SECRET=your-client-secret
# ENTRA_AUDIENCE=api://your-client-id
# ENTRA_REDIRECT_URI=http://dev.cvapp.mashfrog.com:8082/auth/callback

# ── AI Services ───────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key-here
# Modello OpenAI da usare per il parsing (gpt-4o consigliato per accuratezza)
OPENAI_MODEL=gpt-4o

# ── Upload ────────────────────────────────────────────────────────────────────
# Dimensione massima upload in MB
MAX_UPLOAD_SIZE_MB=10
# Tipi MIME accettati (PDF, Word)
ALLOWED_MIME_TYPES=application/pdf,application/vnd.openxmlformats-officedocument.wordprocessingml.document

# ── SharePoint / Microsoft Graph (Application flow) ───────────────────────────
# Le credenziali Azure (ENTRA_*) sono condivise con SSO — non servono variabili extra
# Basta configurare le 3 variabili seguenti:
SHAREPOINT_SITE_URL=https://mashfroggroup.sharepoint.com/sites/ENT_SOLUTION_M4P_STAFF
SHAREPOINT_DRIVE_NAME=Documenti
SHAREPOINT_ROOT_FOLDER=STAFF_DATA_AND_DOCUMENTS
# Struttura cartelle creata automaticamente:
#   Documenti/STAFF_DATA_AND_DOCUMENTS/{user_email}/Certificazioni/cert_{id}.pdf
#   Documenti/STAFF_DATA_AND_DOCUMENTS/{user_email}/CV/cv_{id}.docx
